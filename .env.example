# SendMyMail backend — environment template
# Copy this to .env and fill in your local values. NEVER commit .env (gitignored).

# Express server port
PORT=4000

# Origin allowed by CORS (the frontend dev server)
FRONTEND_ORIGIN=http://localhost:5173

# Public URL of the frontend app — used when building links in transactional emails
# (password reset, invite). In prod this becomes https://app.sendmymail.io.
APP_URL=http://localhost:5173

# Public URL of the backend — used to build the Google OAuth redirect URI.
# In prod this becomes https://api.sendmymail.io.
BACKEND_URL=http://localhost:4000

# 'development' enables the dev email stub (console-logs verification codes / reset URLs /
# invite URLs) and verbose Prisma logging. Set to 'production' in prod.
NODE_ENV=development

# PostgreSQL connection string. NOTE: on Node 20+ use 127.0.0.1 (NOT localhost) — Node
# resolves localhost to IPv6 first and Prisma's PG driver doesn't connect over IPv6.
# Local example (Postgres.app, trust auth, no password):
#   postgresql://<your-macos-username>@127.0.0.1:5432/sendmymail_dev?schema=public
# Hosted example (Neon / Supabase):
#   postgresql://USER:PASS@ep-xxxx.region.aws.neon.tech/sendmymail?sslmode=require
DATABASE_URL="postgresql://USER@127.0.0.1:5432/sendmymail_dev?schema=public"

# JWT signing secret — 32+ random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEVER commit a real value. NEVER reuse across environments.
JWT_SECRET="REPLACE_ME_WITH_32_PLUS_RANDOM_BYTES"

# Google OAuth credentials — get from https://console.cloud.google.com/apis/credentials
# Setup steps:
#   1. Create / pick a Google Cloud project
#   2. APIs & Services → OAuth consent screen → fill in app name, support email, scopes (openid, email, profile)
#   3. APIs & Services → Credentials → Create credentials → OAuth client ID → Web application
#   4. Add Authorized redirect URI: ${BACKEND_URL}/v1/auth/google/callback
#      (e.g. http://localhost:4000/v1/auth/google/callback for dev)
#   5. Copy Client ID + Secret here. NEVER commit real values.
# The auth endpoints work without these (they'll throw a clear 500 explaining what's missing).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — transactional email provider (https://resend.com)
# Get an API key: Resend dashboard → API Keys → Create. NEVER commit a real value here.
# Without this, /v1/auth/signup / verify / forgot / invitations fall back to the dev
# console-log stub (codes / links print to the backend terminal).
RESEND_API_KEY=""

# From-address for transactional emails.
#   Dev (no verified domain): "SendMyMail <onboarding@resend.dev>"
#     Resend's shared dev sender. Will only deliver to the email you signed up to Resend with.
#   Prod (after verifying sendmymail.io in Resend): "SendMyMail <noreply@sendmymail.io>"
EMAIL_FROM=""

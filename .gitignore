# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
jspm_packages/

# ─── Build output ─────────────────────────────────────────────
dist/
build/

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
.tsbuildinfo

# ─── Environment files (NEVER commit secrets) ─────────────────
.env
.env.*
!.env.example

# ─── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Runtime / process files ──────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ─── Testing (Vitest / Jest when added) ───────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Caches ───────────────────────────────────────────────────
.cache/
.eslintcache

# ─── Local dev artifacts ──────────────────────────────────────
# Uploaded files / CSV imports landing locally before going to S3
uploads/
tmp/
temp/

# Local SQLite (if used for dev) — Postgres etc. doesn't need this
*.sqlite
*.sqlite3
*.db
*.db-journal

# ─── Secrets / certificates ───────────────────────────────────
*.pem
*.key
*.crt
*.p12
private/

# ─── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.sw?

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Deploy / hosting (when added) ────────────────────────────
.serverless/
.vercel/
.netlify/
.dockerignore-local

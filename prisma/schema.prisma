// SendMyMail — database schema
// ─────────────────────────────────────────────────────────────────────────────
// Mirror of doc/architecture/auth-flow-and-schema.md §9 + roles-and-permissions.md
// Option B (user_client_scopes join table for per-client scoping).
//
// Conventions:
//  - IDs use cuid() (collision-resistant unique). The docs prescribe ULID with
//    prefixes (agc_, usr_, cli_) but Prisma doesn't support that natively.
//    cuid() is sortable + URL-safe + collision-resistant — fine for V1.
//  - snake_case in Postgres (via @map), camelCase in TypeScript.
//  - JSON columns use Postgres JSONB under the hood.
//  - Server-enforced CHECK constraints (e.g. "owner/admin must have scope=all")
//    aren't declarable in Prisma; for V1 we enforce them in application code
//    and may add a follow-up SQL migration for the CHECK later.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  member
  viewer
}

enum ScopeType {
  all
  clients
}

enum AgencyPlan {
  trial
  starter
  growth
  scale
}

enum ClientStatus {
  trial
  active
  paused
  archived
}

enum InvitationRole {
  admin
  member
  viewer
}

enum OAuthProvider {
  google
  // microsoft  — add post-V1
}

enum ListType {
  static     // hand-managed snapshot
  dynamic    // rule-based, auto-updating — rule JSON ships in feature-contacts-lists PR 3
}

enum ListMembershipStatus {
  subscribed
  unsubscribed   // unsubscribed from this list specifically (client-scoped)
  pending        // confirmation pending — reserved for double-opt-in
}

enum ImportJobStatus {
  pending      // file uploaded, not yet started
  parsing      // detecting headers + counting rows + quality check
  importing    // inserting contacts in chunks
  done
  failed       // either rejected by quality check or threw during import
}

enum CampaignStatus {
  draft        // wizard in progress, no recipient snapshot yet
  scheduled    // V2 — scheduleAt set, awaiting cron / queue
  sending      // launched, send loop running, partial counts in sentCount/failedCount
  sent         // loop finished with ≥1 success
  failed       // loop finished with 0 successes (all sends failed) OR pre-launch validation failed
}

enum SendStatus {
  queued       // row inserted before send attempted (rare — we insert post-attempt V1)
  sent         // Resend returned a messageId
  failed       // Resend rejected or threw; reason in `error`
}

// ─── Tenant + users ──────────────────────────────────────────────────────────

model Agency {
  id            String     @id @default(cuid())
  name          String
  country       String     @default("NP") @db.Char(2) // ISO-3166 alpha-2
  billingEmail  String     @map("billing_email")
  plan          AgencyPlan @default(trial)
  trialEndsAt   DateTime?  @map("trial_ends_at")
  setupComplete Boolean    @default(false) @map("setup_complete")
  subdomain     String?    @unique
  brandingJson  Json?      @map("branding_json")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  users       User[]
  clients     Client[]
  invitations Invitation[]
  auditLogs   AuditLog[]
  contacts    Contact[]
  importJobs  ImportJob[]
  templates   Template[]
  campaigns   Campaign[]

  @@map("agencies")
  @@index([subdomain])
}

model User {
  id               String    @id @default(cuid())
  agencyId         String    @map("agency_id")
  email            String    @unique
  emailVerified    Boolean   @default(false) @map("email_verified")
  passwordHash     String?   @map("password_hash") // nullable for OAuth-only users
  name             String
  role             UserRole
  scopeType        ScopeType @default(all) @map("scope_type")
  avatarUrl        String?   @map("avatar_url")
  lastLoginAt      DateTime? @map("last_login_at")
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  agency              Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  oauthIdentities     OAuthIdentity[]
  clientScopes        UserClientScope[]   @relation("ScopedClients")
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  invitationsSent     Invitation[]        @relation("Inviter")
  invitationsAccepted Invitation[]        @relation("Acceptor")
  auditLogs           AuditLog[]
  scopesGranted       UserClientScope[]   @relation("ScopeGranter")
  importJobs          ImportJob[]
  templatesCreated    Template[]
  campaignsCreated    Campaign[]

  @@map("users")
  @@index([agencyId])
  @@index([email])
}

model OAuthIdentity {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  provider      OAuthProvider
  providerUid   String        @map("provider_uid")   // Google's stable 'sub' claim
  providerEmail String        @map("provider_email") // email at provider, for display
  linkedAt      DateTime      @default(now()) @map("linked_at")
  lastUsedAt    DateTime?     @map("last_used_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("oauth_identities")
  @@unique([provider, providerUid]) // one Google account → one user
  @@index([userId])
}

// ─── Tenant resources ────────────────────────────────────────────────────────

model Client {
  id          String       @id @default(cuid())
  agencyId    String       @map("agency_id")
  name        String
  slug        String                          // URL-safe identifier
  domain      String?                         // sending domain (mail.khukrispices.com)
  avatarColor String?      @map("avatar_color")
  status      ClientStatus @default(trial)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  agency     Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userScopes UserClientScope[]
  contacts   Contact[]
  lists      List[]
  tags       Tag[]
  importJobs ImportJob[]
  templates  Template[]
  campaigns  Campaign[]

  @@map("clients")
  @@unique([agencyId, slug])    // slug unique within an agency
  @@index([agencyId])
}

model UserClientScope {
  userId    String   @map("user_id")
  clientId  String   @map("client_id")
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by")

  user    User   @relation("ScopedClients", fields: [userId], references: [id], onDelete: Cascade)
  client  Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  granter User?  @relation("ScopeGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@id([userId, clientId])
  @@map("user_client_scopes")
  @@index([clientId])
}

// ─── Short-lived tokens ──────────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String   @db.Char(6)              // 000000 – 999999
  expiresAt DateTime @map("expires_at")       // 15 min from issue
  attempts  Int      @default(0)              // max 5
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
  @@index([userId, used])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") // SHA-256 of URL token, never raw
  expiresAt DateTime @map("expires_at")          // 1 hour from issue
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
  @@index([userId, used])
}

model Invitation {
  id             String         @id @default(cuid())
  agencyId       String         @map("agency_id")
  inviterUserId  String?        @map("inviter_user_id")
  email          String                          // lowercased at insert
  role           InvitationRole                  // captured at invite time
  scope          Json                            // { type: "all" } OR { type: "clients", ids: ["cli_..."] }
  tokenHash      String         @unique @map("token_hash")
  expiresAt      DateTime       @map("expires_at") // 7 days
  acceptedAt     DateTime?      @map("accepted_at")
  acceptedUserId String?        @map("accepted_user_id")
  revokedAt      DateTime?      @map("revoked_at")
  supersededAt   DateTime?      @map("superseded_at")
  note           String?                         // optional personal message in email
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at") // bumps on resend — rate-limit reference

  agency     Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  inviter    User?  @relation("Inviter", fields: [inviterUserId], references: [id], onDelete: SetNull)
  acceptedBy User?  @relation("Acceptor", fields: [acceptedUserId], references: [id])

  @@map("invitations")
  @@index([agencyId, acceptedAt])
  @@index([email, acceptedAt])
}

// ─── Audit trail ─────────────────────────────────────────────────────────────

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  agencyId    String   @map("agency_id")
  actorUserId String?  @map("actor_user_id")
  action      String   // e.g. "auth.login" / "team.invite_sent" / "campaign.sent"
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  ip          String?
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@map("audit_log")
  @@index([agencyId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
}

// ─── Contacts, lists, tags (feature-contacts-lists) ──────────────────────────

model Contact {
  id         String    @id @default(cuid())
  agencyId   String    @map("agency_id")
  clientId   String    @map("client_id")
  email      String                                 // preserves case as user typed
  emailLower String    @map("email_lower")          // lowercased copy — uniqueness + lookups
  firstName  String?   @map("first_name")
  lastName   String?   @map("last_name")
  phone      String?
  city       String?
  birthday   DateTime? @db.Date
  custom     Json?                                  // ≤10 client-defined fields (cap enforced in API layer)
  source     String?                                // 'manual' | 'csv_import' | 'form' | 'api' — V1 only manual / csv
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")           // soft-delete; hard-delete + GDPR cascade lands in PR 3

  agency             Agency              @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  listMembers        ListContact[]
  contactTags        ContactTag[]
  campaignRecipients CampaignRecipient[]

  @@map("contacts")
  @@unique([clientId, emailLower])                  // the core dedupe rule
  @@index([clientId, deletedAt])
  @@index([clientId, createdAt])
}

model List {
  id          String   @id @default(cuid())
  agencyId    String   @map("agency_id")
  clientId    String   @map("client_id")
  name        String
  description String?                               // ≤200 chars (API layer)
  type        ListType @default(static)             // dynamic rule JSON lands in PR 3
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members    ListContact[]
  importJobs ImportJob[]
  campaigns  Campaign[]

  @@map("lists")
  @@index([clientId, archived])
}

model ListContact {
  listId          String               @map("list_id")
  contactId       String               @map("contact_id")
  status          ListMembershipStatus @default(subscribed)
  subscribedAt    DateTime             @default(now()) @map("subscribed_at")
  unsubscribedAt  DateTime?            @map("unsubscribed_at")

  list    List    @relation(fields: [listId],    references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
  @@map("list_contacts")
  @@index([contactId])
}

model Tag {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  name      String                                  // lowercased on write; free-text
  color     String?                                 // optional hex; FE assigns one if null
  createdAt DateTime @default(now()) @map("created_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactTags ContactTag[]

  @@map("tags")
  @@unique([clientId, name])
}

model ContactTag {
  contactId String @map("contact_id")
  tagId     String @map("tag_id")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId],     references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
  @@index([tagId])
}

// ─── CSV import jobs (feature-contacts-lists PR 2) ──────────────────────────

model ImportJob {
  id             String          @id @default(cuid())
  agencyId       String          @map("agency_id")
  clientId       String          @map("client_id")
  listId         String?         @map("list_id")        // optional — if set, imported contacts also join this list as subscribed
  createdBy      String          @map("created_by")     // user who initiated
  status         ImportJobStatus @default(pending)
  rejectedReason String?         @map("rejected_reason") // 'too_many_role_accounts' | 'invalid_csv' | 'parse_error'
  filename       String                                  // original upload name (for the history modal)
  fileSize       Int             @map("file_size")
  totalRows      Int             @default(0) @map("total_rows")
  processedRows  Int             @default(0) @map("processed_rows")
  importedRows   Int             @default(0) @map("imported_rows")
  skippedRows    Int             @default(0) @map("skipped_rows")     // duplicates, empty emails
  rejectedRows   Int             @default(0) @map("rejected_rows")    // bad email format, etc.
  columnMapping  Json            @map("column_mapping")                // { csvHeader: 'email' | 'firstName' | … | 'skip' }
  consentText    String          @map("consent_text")                  // exact text the user agreed to (compliance)
  errors         Json?                                                  // first 100 errors as [{ row, email, reason }]
  startedAt      DateTime?       @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  createdAt      DateTime        @default(now()) @map("created_at")

  agency  Agency @relation(fields: [agencyId],  references: [id], onDelete: Cascade)
  client  Client @relation(fields: [clientId],  references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  list    List?  @relation(fields: [listId],    references: [id], onDelete: SetNull)

  @@map("import_jobs")
  @@index([clientId, createdAt(sort: Desc)])
  @@index([status])
}

/* Templates — reusable email designs (feature-templates).
   The MJML tree is persisted as JSON in `mjml_source`. No subject /
   preheader / from columns: those are envelope metadata owned by
   Campaign (Feature 06). `client_id` is nullable so PR 3 can seed
   agency-level starter templates without a follow-up migration. */
model Template {
  id           String   @id @default(cuid())
  agencyId     String   @map("agency_id")
  clientId     String?  @map("client_id")           // null = agency-level reusable (seeded later)
  name         String                                // ≤120 chars, internal label (NOT the email subject)
  mjmlSource   Json     @map("mjml_source")          // IMjmlNode tree, post-strip (no _id, no _meta, no mj-preview)
  thumbnailUrl String?  @map("thumbnail_url")
  category     String?                               // free-text V1
  isStarter    Boolean  @default(false) @map("is_starter")
  archived     Boolean  @default(false)
  createdBy    String?  @map("created_by")           // null if the creating user was deleted (SetNull)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  agency    Agency     @relation(fields: [agencyId],  references: [id], onDelete: Cascade)
  client    Client?    @relation(fields: [clientId],  references: [id], onDelete: Cascade)
  creator   User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  campaigns Campaign[]

  @@map("templates")
  @@index([agencyId])
  @@index([clientId, archived, updatedAt(sort: Desc)])  // hot path: GET list ordered by recency
  @@index([agencyId, isStarter])                         // PR 3's starter lookup
}

/* Campaigns — one-shot broadcasts (feature-campaigns V1).
   The wizard builds a draft; launch snapshots recipients from the
   referenced list and runs the send pipeline (Resend via sendRawHtml).

   Envelope (fromName/fromEmail/subject/preheader) lives here, NOT on
   Template, so one template can be sent by many campaigns with different
   subjects. Mirrors how every ESP works.

   templateId + listId are SetNull on delete so campaigns survive their
   sources being archived — the snapshot in CampaignRecipient is already
   frozen, and sent campaigns aren't re-rendered. */
model Campaign {
  id        String   @id @default(cuid())
  agencyId  String   @map("agency_id")
  clientId  String   @map("client_id")
  name      String                                       // ≤200 chars

  // Envelope metadata (nullable on draft, server enforces required at launch)
  fromName  String?  @map("from_name")
  fromEmail String?  @map("from_email")
  subject   String?
  preheader String?                                       // ≤150 chars

  // Content + audience
  templateId String? @map("template_id")
  listId     String? @map("list_id")

  // Scheduling — V1 always null at launch ("Send now" only); reserved for V2
  scheduleAt DateTime? @map("schedule_at")

  // Lifecycle
  status              CampaignStatus @default(draft)
  recipientSnapshotAt DateTime?      @map("recipient_snapshot_at")
  totalRecipients     Int            @default(0) @map("total_recipients")
  sentCount           Int            @default(0) @map("sent_count")
  failedCount         Int            @default(0) @map("failed_count")

  // Soft-delete (matches templates pattern)
  archived  Boolean  @default(false)

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agency   Agency    @relation(fields: [agencyId],  references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId],  references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  list     List?     @relation(fields: [listId],    references: [id], onDelete: SetNull)
  creator  User?     @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  recipients CampaignRecipient[]
  sends      Send[]

  @@map("campaigns")
  @@index([agencyId])
  @@index([clientId, archived, status, createdAt(sort: Desc)])  // hot path: list filtered by status
}

/* CampaignRecipient — immutable snapshot of who gets the campaign.
   Written at launch time from the list's current contacts; never edited.
   Composite primary key (campaignId, email) prevents within-campaign
   duplicates even if the list contained the same contact twice. */
model CampaignRecipient {
  campaignId String  @map("campaign_id")
  email      String                                // frozen at snapshot
  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  contactId  String? @map("contact_id")            // null if list contained stragglers (V2 manual entry)
  mergeData  Json?   @map("merge_data")            // V2: custom field substitution

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId],  references: [id], onDelete: SetNull)

  @@id([campaignId, email])
  @@map("campaign_recipients")
  @@index([campaignId])
  @@index([contactId])
}

/* Send — per-recipient send attempt log.
   One row per call to Resend. status + error capture the outcome.
   resendMessageId UNIQUE is forward-compat for V2 webhook ingestion
   (deliver / bounce / complaint events keyed by message-id). */
model Send {
  id              String     @id @default(cuid())
  campaignId      String     @map("campaign_id")
  toEmail         String     @map("to_email")     // duplicates CampaignRecipient.email for log clarity
  resendMessageId String?    @unique @map("resend_message_id")
  status          SendStatus @default(queued)
  error           String?                          // Resend's reason on failure
  sentAt          DateTime?  @map("sent_at")
  createdAt       DateTime   @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("sends")
  @@index([campaignId, status])                    // report aggregation
  @@index([campaignId, createdAt(sort: Desc)])     // recipient log ordering
}
